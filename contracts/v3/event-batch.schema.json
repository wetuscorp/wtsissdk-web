{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/sdk/v3/event-batch.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "events"],
  "properties": {
    "schemaVersion": { "const": 3 },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "clientEventId",
          "anonymousId",
          "sessionId",
          "type",
          "occurredAt",
          "metadata",
          "properties"
        ],
        "properties": {
          "schemaVersion": { "const": 3 },
          "clientEventId": { "type": "string", "format": "uuid" },
          "anonymousId": { "type": "string", "format": "uuid" },
          "sessionId": { "type": "string", "format": "uuid" },
          "type": { "enum": ["page_view", "session_start", "custom"] },
          "eventKey": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "occurredAt": { "type": "string", "format": "date-time" },
          "metadata": { "$ref": "common.schema.json#/$defs/metadata" },
          "pathname": {
            "type": "string",
            "pattern": "^/[^?#]*$",
            "maxLength": 2048
          },
          "pageName": { "type": "string", "maxLength": 120 },
          "referrerHost": {
            "type": "string",
            "pattern": "^[a-z0-9.-]+$",
            "maxLength": 253
          },
          "properties": {
            "type": "object",
            "maxProperties": 20,
            "propertyNames": { "pattern": "^[a-z][a-z0-9_]{0,63}$" },
            "additionalProperties": {
              "$ref": "common.schema.json#/$defs/scalar"
            }
          },
          "revenue": { "$ref": "common.schema.json#/$defs/revenue" },
          "attributionContextId": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "page_view" } } },
            "then": { "required": ["pathname"] }
          },
          {
            "if": { "properties": { "type": { "const": "custom" } } },
            "then": { "required": ["eventKey"] }
          }
        ]
      }
    }
  }
}
