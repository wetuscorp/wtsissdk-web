{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/sdk/v3/common.json",
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "sdkVersion", "locale"],
      "properties": {
        "platform": { "const": "web" },
        "sdkVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
        "locale": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "scalar": {
      "oneOf": [{ "type": "string", "maxLength": 512 }, { "type": "number" }, { "type": "boolean" }]
    },
    "revenue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "string", "pattern": "^-?\\d{1,12}(?:\\.\\d{1,6})?$" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    }
  }
}
