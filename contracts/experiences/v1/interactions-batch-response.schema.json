{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/experiences/v1/interactions-batch-response.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["accepted", "duplicates", "rejected"],
  "properties": {
    "accepted": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "duplicates": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "rejected": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clientInteractionId", "code", "message", "retryable"],
        "properties": {
          "clientInteractionId": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" }
        }
      }
    }
  }
}
