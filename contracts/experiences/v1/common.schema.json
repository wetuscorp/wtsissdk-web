{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/experiences/v1/common.json",
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "sdkVersion", "locale"],
      "properties": {
        "platform": { "enum": ["web", "ios", "android"] },
        "sdkVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
        "appVersion": { "type": "string", "maxLength": 64 },
        "osVersion": { "type": "string", "maxLength": 64 },
        "locale": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedInternalRoutes",
        "allowedCallbackKeys",
        "allowedDeepLinkHosts",
        "allowedDeepLinkSchemes",
        "allowedWebOrigins"
      ],
      "properties": {
        "allowedInternalRoutes": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "allowedCallbackKeys": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,63}$" }
        },
        "allowedDeepLinkHosts": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 253 }
        },
        "allowedDeepLinkSchemes": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9+.-]{1,31}$" }
        },
        "allowedWebOrigins": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "format": "uri", "pattern": "^https://" }
        }
      }
    }
  }
}
