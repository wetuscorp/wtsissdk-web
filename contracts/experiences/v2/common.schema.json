{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/experiences/v2/common.json",
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "sdkVersion", "locale"],
      "properties": {
        "platform": { "enum": ["web", "ios", "android"] },
        "sdkVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
        "appVersion": { "type": "string", "maxLength": 64 },
        "osVersion": { "type": "string", "maxLength": 64 },
        "locale": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "onlineKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "algorithm", "publicKey", "notBefore", "expiresAt"],
      "properties": {
        "keyId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "algorithm": { "const": "Ed25519" },
        "publicKey": { "type": "string", "minLength": 32, "maxLength": 256 },
        "notBefore": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "onlineKeyset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "issuedAt", "expiresAt", "keys", "signedPayload", "rootSignature"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "issuedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "keys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/onlineKey" }
        },
        "signedPayload": { "type": "string", "minLength": 1 },
        "rootSignature": { "type": "string", "minLength": 1 }
      }
    }
  }
}
