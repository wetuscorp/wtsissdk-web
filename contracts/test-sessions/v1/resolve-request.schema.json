{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/sdk/test-sessions/v1/resolve-request.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "participantId", "sessionToken", "url"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "participantId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "sessionToken": { "type": "string", "minLength": 32, "maxLength": 512 },
    "url": { "type": "string", "format": "uri", "pattern": "^https://", "minLength": 1, "maxLength": 2048 }
  }
}
