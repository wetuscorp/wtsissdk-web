{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wts.is/schemas/sdk/test-sessions/v2/signals-batch.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "participantId", "sessionToken", "signals"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "participantId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "sessionToken": { "type": "string", "minLength": 32, "maxLength": 512 },
    "signals": { "$ref": "../v1/signals-batch.schema.json#/properties/signals" }
  }
}
