{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": { "@wetusco/wts-web-sdk": ["./src/index.ts"] },
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "allowJs": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src",
    "tests",
    "examples/vite/src.ts",
    "scripts",
    "tsup.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
